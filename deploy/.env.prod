# 学院综合服务平台 - 生产环境配置
# 部署到服务器前请修改以下敏感配置

# 数据库
DB_NAME=college_service
DB_USER=postgres
DB_PASSWORD=College@2024!Secure

# Redis
REDIS_PASSWORD=

# JWT 密钥（至少32字符）
JWT_SECRET=CollegeServicePlatformJwtSecret2024!@#$

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# ====== 大模型 API (智能问答可选增强) ======
# 默认 none 时不调用外部大模型；RAG 仍会用文档片段做抽取式回答
# 当前后端内置的 http provider 期望目标接口接收:
#   POST JSON: { "question": "...", "context": "..." }
# 并返回 answer/result/data.answer 或 OpenAI choices[0].message.content
AI_PROVIDER=none
AI_API_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=5000

# ====== 邮件 SMTP (模块三 信息精准推送) ======
# 授权码留空时, EmailService 自动降级为只写 email_sim 站内通知, 不阻塞业务
# MAIL_AUTH_CODE 必须在邮箱后台单独生成 (不是登录密码), 不同服务商互不通用
#
# 当前默认: RUC 学校邮箱 (托管在网易企业邮杭州节点)
#   SMTP 服务器:  smtphz.qiye.163.com
#   端口:        465 (SSL)   ← 注意 SMTP 是 465; 994 是 IMAP, 995 是 POP3, 别填错
#   授权码:      在 https://mail.ruc.edu.cn 登录后, 设置 → 客户端授权密码 中生成
#
# 其他常见服务商参考:
#   QQ 个人邮箱:    smtp.qq.com:465
#   QQ 企业邮箱:    smtp.exmail.qq.com:465
#   网易企业邮(通用): smtp.qiye.163.com:465
MAIL_HOST=smtphz.qiye.163.com
MAIL_PORT=465
MAIL_USERNAME=2024201564@ruc.edu.cn
MAIL_AUTH_CODE=
